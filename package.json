{
  "name": "@inferagraph/anthropic-provider",
  "version": "0.3.3",
  "description": "Anthropic Claude provider for InferaGraph (with optional Voyage AI embeddings)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inferagraph/anthropic-provider.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "packageManager": "pnpm@10.33.2",
  "license": "MIT",
  "peerDependencies": {
    "@inferagraph/core": "^0.10.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "voyageai": "^0.2.1"
  },
  "devDependencies": {
    "@inferagraph/core": "^0.10.1",
    "@vitest/coverage-v8": "^3.1.1",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.1"
  }
}
